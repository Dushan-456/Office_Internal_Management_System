// ----------------------------------------------------------------------------------------------------------------------------------------------------------------------
// PRISMA CLIENT CONFIG
// ----------------------------------------------------------------------------------------------------------------------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Identity
enum EmployeeType {
  Assignment_Basis
  Probation
  Contract
  Temporary
  Permanent
}

enum Department {
  Academic
  Finance
  MERC
  Computer
  General_Administration
  Examination
  Library
}

enum JobCategory {
  Administrative_and_Finance
  Academic_Support
  Primary_Level
  Academic
  Clerical_and_Allied
  Technical
}

enum Grade {
  Grade_I
  Grade_II
  Grade_III
  NA
}

enum Role {
  ADMIN
  DEPT_HEAD
  EMPLOYEE
}

model User {
  id              String   @id @default(uuid())
  
  // Identity
  employeeNo      String   @unique
  epfNo           String?  @unique
  fingerPrintId   String?  @unique
  nicNo           String   @unique
  email           String   @unique
  password        String
  
  // Personal
  firstName       String
  lastName        String
  maritalStatus   String?
  gender          String?
  dob             DateTime?
  nationality     String?
  address         String?
  district        String?
  mobileNo        String?
  
  // Employment
  dateJoined      DateTime
  employeeType    EmployeeType
  department      Department
  jobCategory     JobCategory
  jobTitle        JobTitle
  grade           Grade      @default(NA)
  role            Role       @default(EMPLOYEE)
  qualifications  Json?
  
  // Relations
  leavesAsEmployee          LeaveRequest[] @relation("Applicant")
  leavesAsActingOfficer     LeaveRequest[] @relation("ActingOfficer")
  leavesAsApproveOfficer    LeaveRequest[] @relation("ApproveOfficer")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum JobTitle {
  Assistant_Bursar
  Clerk
  Course_Coordinator
  Computer_programmer
  Deputy_Bursar
  Lab_Attendant
  Assistant_Librarian
  Computer_Application_Assistant
  Deputy_Registrar
  Electrician
  Laborer___Works_aid
  Assistant_Registrar
  Computer_Programmer_cum_System_Analyst
  Cycle_Orderly
  Driver
  Lecturer
  Library_Assistant
  Management_Assistant
  Receptionist
  Senior_Assistant_Registrar
  Senior_Technical_Officer
  Technical_Officer
  Work_Superintendent
  Office_Machine_Operator
  Senior_Assistant_Bursar
  Senior_Lecturer
  Staff_Assistant
  Trainee_Technical_Officer
  Office_Assistant
  Senior_Assistant_Librarian
  Senior_Staff_Assistant
  Stenographer
  Work_Supervisor
  Programme_Assistant
  Research_Assistant
}

enum LeaveType {
  Casual
  Vacation
  Medical
  No_Pay
  Study
  Sabbatical
  Maternity
  Paternal
  Duty
  Lieu
  Special
  Other
}

enum LeaveCategory {
  Full_Day
  Half_Day
}

enum LeaveStatus {
  Pending_Acting
  Pending_Approval
  Approved
  Rejected
}

model LeaveRequest {
  id              String   @id @default(uuid())
  
  leaveType       LeaveType
  category        LeaveCategory
  startDate       DateTime
  endDate         DateTime
  reason          String @db.Text
  addressOnLeave  String? @db.Text
  attachmentUrl   String? // File path
  
  status          LeaveStatus @default(Pending_Acting)
  totalDays       Float
  
  applicantId     String
  applicant       User @relation("Applicant", fields: [applicantId], references: [id])
  
  actingOfficerId   String?
  actingOfficer     User? @relation("ActingOfficer", fields: [actingOfficerId], references: [id])
  
  approveOfficerId  String?
  approveOfficer    User? @relation("ApproveOfficer", fields: [approveOfficerId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Attendance {
  id              String   @id @default(uuid())
  employeeNo      String
  employeeName    String?
  date            DateTime
  checkIn         String
  checkOut        String
  status          String
  createdAt       DateTime @default(now())
}
